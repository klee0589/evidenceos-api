# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
ALLOWED_ORIGIN=https://your-landing-page.com   # Lock this down in production
APP_URL=https://evidenceos.com
UPGRADE_URL=https://evidenceos.com/pricing

# ── Database ──────────────────────────────────────────────────────────────────
# Defaults to ./data/evidenceos.db if not set.
# For Render, use /opt/render/project/src/data/evidenceos.db or attach a disk.
DB_PATH=./data/evidenceos.db

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_JWT_SECRET=change-me-to-a-long-random-string   # openssl rand -hex 32

# ── Base44 Billing ────────────────────────────────────────────────────────────
# Shared secret — set this in Base44's automation webhook headers as X-Webhook-Secret
BASE44_WEBHOOK_SECRET=change-me-to-a-long-random-string

# ── Google Workspace ──────────────────────────────────────────────────────────
# Service account JSON (base64-encoded or raw JSON string)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_ADMIN_EMAIL=admin@yourdomain.com

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...    # read:org scope required
GITHUB_ORG=your-org-name

# ── AWS IAM ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# ── Okta ─────────────────────────────────────────────────────────────────────
OKTA_DOMAIN=dev-123456.okta.com   # no https:// prefix
OKTA_API_TOKEN=00...
